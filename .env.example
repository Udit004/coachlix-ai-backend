NODE_ENV=development
HOST=0.0.0.0
PORT=8080
FRONTEND_ORIGIN=http://localhost:3000

MONGODB_URI=

GEMINI_API_KEY=
GEMINI_API_VERSION=v1alpha
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
GEMINI_VOICE_NAME=Aoede
AUDIO_INPUT_MIME_TYPE=audio/pcm;rate=16000
LIVE_SYSTEM_INSTRUCTION=You are Coachlix AI fitness coach. Keep responses concise, practical, and safe.


# Your LangSmith API key (get from https://smith.langchain.com/settings)
LANGCHAIN_API_KEY=

# Project name in LangSmith (helps organize traces)
LANGCHAIN_PROJECT=coachlix-ai-fitness
LANGCHAIN_VERBOSE=true
LANGCHAIN_TRACING_V2=true

# Firebase Admin SDK Configuration
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=
FIREBASE_ADMIN_CREDENTIALS=
FIREBASE_ADMIN_CREDENTIALS_BASE64=

# Cloudinary Configuration
CLOUD_NAME=
CLOUD_API_KEY=
CLOUD_API_SECRET=